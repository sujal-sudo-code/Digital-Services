# ==================================================
# Digital Services Backend — Environment Variables
# ==================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==================================================

# Server
PORT=5000

# MongoDB (required)
# Use MongoDB Atlas connection string or local URI
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT Secret (required — use a strong random string, min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Admin Credentials (used for initial seed only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# CORS — comma-separated list of allowed frontend origins
# Leave empty to use default localhost origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Email Configuration (Nodemailer — optional)
# For Gmail: use an App Password, not your regular password
# Steps: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=your-email@gmail.com
